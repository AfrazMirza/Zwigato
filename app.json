{
  "expo": {
    "name": "ZwigatoShop",
    "slug": "ZwigatoShop",
    "scheme": "zwigato-shop",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/zwigato.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ff3f6c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.afrazmirza.ZwigatoShop"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "splash": {
        "resizeMode": "contain",
        "backgroundColor": "#ff3f6c"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.afrazmirza.ZwigatoShop"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0ed4ca1c-5dde-4f4a-900a-e2a933f1fc9d"
      }
    },
    "owner": "afrazmirza"
  }
}
